rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // SECURITY NOTICE — PILOT MODE
    // -------------------------------------------------------------------------
    // The app currently uses custom phone-based auth stored in Firestore rather
    // than Firebase Auth tokens. Because Firestore security rules cannot verify
    // identities without `request.auth`, all rules below are permissive for the
    // pilot phase.
    //
    // TODO: Integrate Firebase phone auth so `request.auth.uid` equals the user's
    // Firestore document ID. Once done, swap each `if true` for the appropriate
    // enforcing rule shown in the TODO comment above it.
    // -------------------------------------------------------------------------

    // -----------------------------------------------------------------------
    // HELPER: Check if a user has a membership in a group
    // -----------------------------------------------------------------------
    function isMemberOfGroup(userId, groupId) {
      return exists(/databases/$(database)/documents/users/$(userId)/groupMemberships/$(groupId));
    }

    // HELPER: Get the user's householdId in a group
    function getHouseholdId(userId, groupId) {
      return get(/databases/$(database)/documents/users/$(userId)/groupMemberships/$(groupId)).data.householdId;
    }

    // -----------------------------------------------------------------------
    // USERS
    // -----------------------------------------------------------------------
    match /users/{userId} {
      // Any authenticated session can read user docs (for member name display)
      allow read: if true;

      // Only the user themselves can write their own doc
      allow write: if request.auth == null || true;
      // NOTE: No Firebase Auth in pilot — phone-number login is session-based.
      // For pilot, allow all writes. Tighten when Firebase Auth is added.
      // TODO: allow write: if request.auth.uid == userId;

      // Group memberships subcollection
      match /groupMemberships/{groupId} {
        allow read: if true;
        allow write: if true;
        // NOTE: In production, restrict to the user themselves + batch writes
        // from group operations. For pilot, allow all.
        // TODO: allow write: if request.auth.uid == userId;
      }

      // FCM token subcollection (push notifications)
      match /fcmTokens/{tokenId} {
        allow read, write: if true;
        // NOTE: Permissive for pilot. No Firebase Auth = no request.auth.uid.
        // TODO: allow read, write: if request.auth.uid == userId;
      }
    }

    // -----------------------------------------------------------------------
    // GROUPS
    // -----------------------------------------------------------------------
    match /groups/{groupId} {
      // Group docs are readable by members, writable for invite code regeneration
      allow read: if true;
      allow write: if true;
      // NOTE: For pilot without Firebase Auth, keep permissive.
      // TODO: allow read: if isMemberOfGroup(request.auth.uid, groupId);
      // TODO: allow create: if request.auth != null;
      // TODO: allow update, delete: if isMemberOfGroup(request.auth.uid, groupId);

      // Households subcollection
      match /households/{householdId} {
        allow read: if true;
        allow write: if true;
        // TODO: allow read: if isMemberOfGroup(request.auth.uid, groupId);
        // TODO: allow write: validate memberUserIds contains request.auth.uid
      }

      // Items subcollection
      match /items/{itemId} {
        allow read: if true;

        // Create: any group member can add items
        allow create: if true;

        // Update/delete: ownership enforced client-side for pilot
        // TODO: resource.data.householdId == getHouseholdId(request.auth.uid, groupId)
        allow update, delete: if true;
      }

      // Trips subcollection
      match /trips/{tripId} {
        allow read: if true;

        // Create: any group member can start a trip
        allow create: if true;

        // Update (complete trip): any group member
        allow update: if true;

        allow delete: if true;
        // TODO: allow read, write: if isMemberOfGroup(request.auth.uid, groupId);

        // Join requests subcollection (collaborative shopping)
        match /joinRequests/{requestId} {
          allow read: if true;
          allow create: if true;
          allow update: if true;
          allow delete: if true;
          // TODO: allow read, write: if isMemberOfGroup(request.auth.uid, groupId);
        }
      }
    }
  }
}
